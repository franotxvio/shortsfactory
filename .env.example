APP_ENV=development
APP_NAME=ShortsFactory
APP_DEBUG=true

DATABASE_URL=postgresql+asyncpg://shortsfactory:shortsfactory@localhost:5432/shortsfactory
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx

MAX_COST_PER_VIDEO_USD=0.40
DAILY_BUDGET_USD=5.00

LOCAL_STORAGE_PATH=./storage
ASSET_POOL_PATH=./storage/assets
AUDIO_OUTPUT_PATH=./storage/audio
CAPTION_OUTPUT_PATH=./storage/captions
PREVIEW_OUTPUT_PATH=./storage/renders/previews
FINAL_OUTPUT_PATH=./storage/renders/finals

FFMPEG_PATH=ffmpeg
WHISPER_MODEL=base
